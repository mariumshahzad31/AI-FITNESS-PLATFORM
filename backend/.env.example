# AI Fitness Platform — Backend configuration
PORT=5000
NODE_ENV=development

# PostgreSQL connection string.
# Local dev runs the project database on host port 5433 (see docker-compose `db`
# service) so it never clashes with any PostgreSQL already using 5432.
DATABASE_URL=postgresql://fitness_user:fitness_password@localhost:5433/ai_fitness_platform

# Frontend origin allowed by CORS (no wildcard)
FRONTEND_ORIGIN=http://localhost:3000

# AI / ML service
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT_MS=15000

# JWT secrets — generate strong random values for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-another-strong-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
BCRYPT_ROUNDS=10

# Optional: override the public Overpass endpoint for nearby venues
# OVERPASS_URL=https://overpass-api.de/api/interpreter
